NEXT_PUBLIC_API_BASE_URL=https://api.example-tunnel.dev
NEXT_PUBLIC_BACKEND_VERSION=v1
NEXT_PUBLIC_GOOGLE_OAUTH_WEB_CLIENT_ID=web-client-id.apps.googleusercontent.com

# IDE embedded previews (Cursor Simple Browser, etc.) often block geolocation entirely.
# In `pnpm dev`, set below to bypass the startup location gate — only for smoke tests / UI.
# NEXT_PUBLIC_SKIP_LOCATION_GUARD_DEV=true
